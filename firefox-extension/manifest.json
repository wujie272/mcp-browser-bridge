{
  "manifest_version": 2,
  "name": "MCP Browser Bridge",
  "version": "2.0.0",
  "description": "将手机 Firefox 浏览器暴露给 Termux MCP 使用，支持 AI 操控浏览器。v2: 书签/历史/下载/窗口/截图/网络拦截/控制台监控",
  "author": "MCP Bridge",

  "browser_specific_settings": {
    "gecko": {
      "id": "mcp-bridge@termux",
      "strict_min_version": "91.0"
    }
  },

  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "<all_urls>",
    "webNavigation",
    "cookies",
    "clipboardWrite",
    "clipboardRead",
    "bookmarks",
    "history",
    "downloads",
    "notifications",
    "contextMenus",
    "alarms"
  ],

  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false,
      "match_about_blank": false
    }
  ],

  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_title": "MCP Browser Bridge v2.0",
    "default_icon": {
      "48": "icons/icon.svg",
      "96": "icons/icon.svg"
    }
  },

  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  }
}
